description="Bridge a NUT-monitored UPS into a virtual battery for UPower"

command="/usr/bin/nut-to-fakebattery"
supervisor="supervise-daemon"
respawn_delay=5
pidfile="/run/${RC_SVCNAME}.pid"

depend() {
	need upsd
	use upsmon
}
